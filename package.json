{
  "name": "performance-checker",
  "version": "2.0.0",
  "description": "4-layer performance audit system for Vue/React frontend projects (static + runtime + AI + dashboard)",
  "type": "module",
  "bin": {
    "perf-check": "./bin/perf-check.js"
  },
  "scripts": {
    "check": "node bin/perf-check.js",
    "check:bundle": "node bin/perf-check.js --layer bundle",
    "check:lint": "node bin/perf-check.js --layer lint",
    "check:deps": "node bin/perf-check.js --layer deps",
    "report": "node bin/perf-check.js --report",
    "scan": "node bin/perf-check.js scan",
    "dashboard": "node bin/perf-check.js dashboard",
    "server": "node server/index.js",
    "ui": "npm --prefix ui run dev",
    "ui:build": "npm --prefix ui run build",
    "dev": "concurrently -k -n server,ui -c blue,magenta \"npm:server\" \"npm:ui\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@vue/compiler-sfc": "^3.5.34",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.3.0",
    "chrome-launcher": "^1.2.1",
    "commander": "^12.1.0",
    "dependency-cruiser": "^17.4.2",
    "fastify": "^5.8.5",
    "glob": "^11.0.0",
    "lighthouse": "^13.3.0",
    "nanoid": "^5.1.11",
    "ora": "^8.1.1",
    "p-limit": "^7.3.0",
    "playwright": "^1.60.0",
    "table": "^6.8.2",
    "web-vitals": "^5.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "concurrently": "^9.2.1",
    "pino-pretty": "^13.1.3",
    "vitest": "^4.1.7"
  }
}
